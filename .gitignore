# Dependencies
# This tells Git to ignore the huge folder of temporary packages.
/node_modules

# Build output
# This tells Git to ignore the folder with the finished website build.
/dist

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
# This tells Git to ignore any secret keys or local settings.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Local Netlify folder
.netlify
